# Doxyfile for threshold-eval library
# Generated for Sphinx/Breathe integration

# Input configuration
INPUT = ../../include/threshold_eval.h ../../include/threshold_eval_conf.h
RECURSIVE = NO

# Output configuration
OUTPUT_DIRECTORY = ../_build/doxygen
GENERATE_XML = YES
XML_OUTPUT = xml
GENERATE_HTML = NO
GENERATE_LATEX = NO

# Content filtering
FILTER_PATTERNS =

# Build options
QUIET = NO
WARNINGS = YES
WARN_IF_UNDOCUMENTED = NO
WARN_IF_DOC_ERROR = YES

# Configuration for reading the input files
FILE_PATTERNS = *.h *.c

# Preprocessing
ENABLE_PREPROCESSING = YES
MACRO_EXPANSION = YES
PREDEFINED = THRESHOLD_EVAL_MAX=4000000.0f \
             THRESHOLD_EVAL_EPSILON=1.0e-3f
